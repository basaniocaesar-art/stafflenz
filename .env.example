# Supabase (get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your_64_char_hex_secret_here

# Super admin credentials (for first-time setup)
SUPER_ADMIN_EMAIL=admin@stafflenz.com
SUPER_ADMIN_PASSWORD=ChangeThisSecurely123!

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://stafflenz.vercel.app
