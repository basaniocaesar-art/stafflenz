# Supabase (get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your_64_char_hex_secret_here

# Super admin credentials (for first-time setup)
SUPER_ADMIN_EMAIL=admin@lenzai.org
SUPER_ADMIN_PASSWORD=ChangeThisSecurely123!

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://lenzai.org

# Razorpay (Dashboard > Settings > API Keys — use test mode first)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# Razorpay Dashboard > Settings > Webhooks — set the webhook URL to
# https://www.lenzai.org/api/billing/webhook and paste the generated
# secret here. This secret is used to verify incoming webhook signatures.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
# Exposed to the browser so the checkout widget can initialise. OK to
# leak — Razorpay key_id is public; the secret is NOT.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Stripe (Dashboard > Developers > API keys — use test mode first)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx
# Stripe Dashboard > Developers > Webhooks — add endpoint
# https://www.lenzai.org/api/billing/stripe/webhook and copy the
# "Signing secret" (whsec_...) here.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx
